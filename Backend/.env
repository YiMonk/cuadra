# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Desarrollo local — SQLite
DATABASE_URL="sqlite+aiosqlite:///./dev.db"
# Producción — Neon PostgreSQL (descomentar y rellenar)
# DATABASE_URL="postgresql://usuario:password@ep-xxxxx.us-east-2.aws.neon.tech/cuadra?sslmode=require"

# ─── AUTENTICACIÓN JWT ────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="reemplazar_con_string_aleatorio_de_64_bytes"
JWT_EXPIRES_IN="7d"

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Dominio del frontend (en desarrollo: localhost, en producción: tu dominio Vercel)
CORS_ORIGIN="http://localhost:3000"

# ─── EMAIL (reemplaza Firebase Functions/nodemailer) ──────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu@email.com"
SMTP_PASS="app_password_de_gmail"
SMTP_FROM="Cuadra <no-reply@cuadra.app>"

# ─── ALMACENAMIENTO DE IMÁGENES (opcional) ────────────────────────────────────
# Opción A: mantener Firebase Storage
FIREBASE_STORAGE_BUCKET="cuadra-bf832.appspot.com"
FIREBASE_SERVICE_ACCOUNT_PATH="./cuadra-bf832-firebase-adminsdk.json"

# Opción B: Cloudflare R2
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="cuadra-assets"
