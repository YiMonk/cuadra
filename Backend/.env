# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Desarrollo local — SQLite
DATABASE_URL="sqlite+aiosqlite:///./dev.db"
# Producción — Neon PostgreSQL (cambiar DATABASE_URL y NODE_ENV=production en el hosting)
# DATABASE_URL="postgresql://neondb_owner:npg_CGJNX07cHtPk@ep-sparkling-forest-aqep63s8-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
NEON_STRING="postgresql://neondb_owner:npg_CGJNX07cHtPk@ep-sparkling-forest-aqep63s8-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# ─── AUTENTICACIÓN JWT ────────────────────────────────────────────────────────
JWT_SECRET="dev-secret-change-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=7

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
NODE_ENV="development"

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:3000"
