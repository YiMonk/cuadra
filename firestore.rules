rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      let d = getUserData();
      return d != null ? d.get('role', null) : null;
    }

    function getEffectiveOwnerId() {
      let d = getUserData();
      return d == null ? null :
        (d.get('role', null) == 'owner' ? request.auth.uid : d.get('ownerId', null));
    }

    function isAdminGod() {
      return isAuthenticated() && getRole() == 'admingod';
    }

    function isAdmin() {
      return isAuthenticated() && getRole() in ['admingod', 'admin'];
    }

    function isOwner() {
      return isAuthenticated() && getRole() == 'owner';
    }

    function ownerIdMatches(docOwnerId) {
      return isAuthenticated() && (
        docOwnerId == getEffectiveOwnerId()
        || (docOwnerId == null && getRole() in ['owner', 'staff', 'admin', 'admingod'])
      );
    }

    // True when a document has no ownerId yet (legacy data created before multi-tenancy)
    function isLegacyDoc() {
      return resource.data.get('ownerId', null) == null;
    }

    // Users allowed to claim/stamp legacy documents with their ownerId
    function canClaimLegacy() {
      return isAuthenticated() && getRole() in ['owner', 'admin', 'admingod'];
    }

    function isNotChangingProtectedFields() {
      return !request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(['role', 'active', 'subscriptionEndsAt', 'subscriptionPrice']);
    }

    match /users/{userId} {
      allow read: if isAdmin()
        || request.auth.uid == userId
        || (isAuthenticated() && resource.data.get('ownerId', null) == getEffectiveOwnerId());
      allow create: if
        (request.auth.uid == userId
          && request.resource.data.role == 'owner'
          && request.resource.data.active == true)
        || (isOwner()
          && request.resource.data.role == 'staff'
          && request.resource.data.ownerId == request.auth.uid
          && request.resource.data.active == true)
        || isAdmin();
      allow update: if (request.auth.uid == userId && isNotChangingProtectedFields())
        || isAdmin();
      allow delete: if isAdminGod();
    }

    match /products/{productId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null))
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0;
      // Allow normal updates (ownerId immutable) OR migration (stamping legacy docs)
      allow update: if ownerIdMatches(resource.data.get('ownerId', null))
        && (isLegacyDoc() && canClaimLegacy()
            || request.resource.data.get('ownerId', null) == resource.data.get('ownerId', null));
      allow delete: if (isOwner() && request.auth.uid == resource.data.get('ownerId', null)) || isAdminGod();
    }

    match /sales/{saleId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null))
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.status in ['paid', 'pending']
        && request.resource.data.paymentMethod in ['cash', 'transfer', 'mobile_pay', 'credit'];
      // Migration: allow stamping ownerId on legacy docs. Normal: block changing key fields.
      allow update: if ownerIdMatches(resource.data.get('ownerId', null))
        && (isLegacyDoc() && canClaimLegacy()
            || (request.resource.data.get('ownerId', null) == resource.data.get('ownerId', null)
                && !request.resource.data.diff(resource.data)
                    .affectedKeys().hasAny(['items', 'total', 'createdBy', 'ownerId'])));
      allow delete: if isAdminGod();
    }

    match /clients/{clientId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null));
      allow update: if ownerIdMatches(resource.data.get('ownerId', null))
        && (isLegacyDoc() && canClaimLegacy()
            || request.resource.data.get('ownerId', null) == resource.data.get('ownerId', null));
      allow delete: if (isOwner() && request.auth.uid == resource.data.get('ownerId', null)) || isAdminGod();
    }

    match /categories/{catId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null));
      allow update: if ownerIdMatches(resource.data.get('ownerId', null));
      allow delete: if (isOwner() && request.auth.uid == resource.data.get('ownerId', null)) || isAdminGod();
    }

    match /cashboxes/{cashboxId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isOwner()
        && request.resource.data.get('ownerId', null) == request.auth.uid;
      // Allow normal owner updates OR migration (legacy docs with null ownerId)
      allow update, delete: if isAdminGod()
        || (isOwner() && request.auth.uid == resource.data.get('ownerId', null))
        || (isLegacyDoc() && canClaimLegacy());
    }

    match /locations/{locationId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isOwner()
        && request.resource.data.get('ownerId', null) == request.auth.uid;
      allow update, delete: if isAdminGod()
        || (isOwner() && request.auth.uid == resource.data.get('ownerId', null))
        || (isLegacyDoc() && canClaimLegacy());
    }

    match /stock_movements/{movId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null));
      allow update, delete: if isAdminGod()
        || (isLegacyDoc() && canClaimLegacy());
    }

    match /admin_activities/{activityId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.adminId == request.auth.uid;
      allow update, delete: if false;
    }

    match /cashSessions/{sessionId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null));
      allow update: if ownerIdMatches(resource.data.get('ownerId', null));
      allow delete: if isAdminGod()
        || (isOwner() && request.auth.uid == resource.data.get('ownerId', null));
    }

    match /cashClosings/{closingId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null));
      allow update: if ownerIdMatches(resource.data.get('ownerId', null));
      allow delete: if isAdminGod()
        || (isOwner() && request.auth.uid == resource.data.get('ownerId', null));
    }

    match /app_config/{docId} {
      allow read: if docId == 'version' || isAdminGod();
      allow write: if isAdminGod();
    }

    match /expenses/{expenseId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null));
      allow update: if ownerIdMatches(resource.data.get('ownerId', null));
      allow delete: if isAdminGod()
        || (isOwner() && request.auth.uid == resource.data.get('ownerId', null));
    }

    match /suppliers/{supplierId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null));
      allow update: if ownerIdMatches(resource.data.get('ownerId', null));
      allow delete: if isAdminGod()
        || (isOwner() && request.auth.uid == resource.data.get('ownerId', null));
    }

    match /promotions/{promotionId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null));
      allow update: if ownerIdMatches(resource.data.get('ownerId', null));
      allow delete: if isAdminGod()
        || (isOwner() && request.auth.uid == resource.data.get('ownerId', null));
    }

    match /priceLists/{priceListId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null));
      allow update: if ownerIdMatches(resource.data.get('ownerId', null));
      allow delete: if isAdminGod()
        || (isOwner() && request.auth.uid == resource.data.get('ownerId', null));
    }

    match /coupons/{couponId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null));
      allow update: if ownerIdMatches(resource.data.get('ownerId', null));
      allow delete: if isAdminGod()
        || (isOwner() && request.auth.uid == resource.data.get('ownerId', null));
    }

    match /stockTransfers/{transferId} {
      allow read: if ownerIdMatches(resource.data.get('ownerId', null)) || isAdminGod();
      allow create: if isAuthenticated()
        && ownerIdMatches(request.resource.data.get('ownerId', null));
      allow update: if ownerIdMatches(resource.data.get('ownerId', null));
      allow delete: if isAdminGod()
        || (isOwner() && request.auth.uid == resource.data.get('ownerId', null));
    }
  }
}
