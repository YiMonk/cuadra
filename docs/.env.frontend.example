# ─── BACKEND API ──────────────────────────────────────────────────────────────
# URL del cuadra-backend desplegado
# Desarrollo:   http://localhost:4000
# Producción:   https://cuadra-backend.railway.app  (o tu dominio de Railway/Render)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── VARIABLES ELIMINADAS (Firebase — ya no se usan) ─────────────────────────
# NEXT_PUBLIC_FIREBASE_API_KEY          ← eliminar
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN      ← eliminar
# NEXT_PUBLIC_FIREBASE_PROJECT_ID       ← eliminar
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET   ← eliminar (a menos que se mantenga solo Storage)
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID ← eliminar
# NEXT_PUBLIC_FIREBASE_APP_ID           ← eliminar
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID  ← eliminar
