# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Neon PostgreSQL — copiar desde neon.tech > proyecto > Connection String
DATABASE_URL="postgresql://usuario:password@ep-xxxxx.us-east-2.aws.neon.tech/cuadra?sslmode=require"

# ─── AUTENTICACIÓN JWT ────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="reemplazar_con_string_aleatorio_de_64_bytes"
JWT_EXPIRES_IN="7d"

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Dominio del frontend (en desarrollo: localhost, en producción: tu dominio )
CORS_ORIGIN=""

# ─── EMAIL (reemplaza Firebase Functions/nodemailer) ──────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu@email.com"
SMTP_PASS="app_password_de_gmail"
SMTP_FROM="Cuadra <no-reply@cuadra.app>"

